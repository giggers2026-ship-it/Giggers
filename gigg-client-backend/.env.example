# Server
PORT=4000
NODE_ENV=development

# JWT — used for issuing tokens after OTP verify
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=30d

# Supabase (service role — bypasses RLS for server-side operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# MSG91 (OTP via Indian SMS gateway)
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=GIGGAP

# Twilio (alternative OTP — fill if using Twilio instead of MSG91)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
